<settings>
    <servers>
        <server>
            <id>claimo-claimo-backend</id>
            <username>aws</username>
            <password>${env.CODEARTIFACT_AUTH_TOKEN}</password>
        </server>
    </servers>
    <profiles>
        <profile>
            <id>claimo-claimo-backend</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <repositories>
                <repository>
                    <id>claimo-claimo-backend</id>
                    <url>
                        https://claimo-632630731355.d.codeartifact.eu-central-1.amazonaws.com/maven/claimo-backend/</url>
                </repository>
            </repositories>
            <pluginRepositories>
                <pluginRepository>
                    <id>claimo-claimo-backend</id>
                    <name>CodeArtifact Plugins</name>
                    <url>
                        https://claimo-632630731355.d.codeartifact.eu-central-1.amazonaws.com/maven/claimo-backend/</url>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                </pluginRepository>
            </pluginRepositories>
        </profile>
    </profiles>
    <mirrors>
        <mirror>
            <id>claimo-claimo-backend</id>
            <name>claimo-claimo-backend</name>
            <url>
                https://claimo-632630731355.d.codeartifact.eu-central-1.amazonaws.com/maven/claimo-backend/</url>
            <mirrorOf>*</mirrorOf>
        </mirror>
    </mirrors>
</settings>